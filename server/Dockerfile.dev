# ---- Local Development Dockerfile ----
# Hot-reload enabled, mounts source code via volume
FROM node:22-alpine

WORKDIR /app

COPY package.json package-lock.json* ./

RUN npm ci

COPY tsconfig.json ./
COPY . .

RUN mkdir -p /app/public/uploads

RUN chmod +x entrypoint.sh

EXPOSE 5011

CMD ["sh", "-c", "npx ts-node --transpile-only scripts/seed.ts && npx ts-node-dev --respawn --transpile-only index.ts"]
